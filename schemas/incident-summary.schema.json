{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://resqlink.dev/schemas/incident-summary.schema.json",
  "title": "IncidentSummary (Output)",
  "description": "One-glance operational snapshot of a single incident. Returned by GET /v1/incidents/{id}/summary. A read-model aggregated from artifacts / reviews / reports.",
  "type": "object",
  "required": ["incident_id", "slug", "title", "severity", "status", "artifacts", "reviews", "reports", "readiness"],
  "properties": {
    "incident_id": { "type": "string", "format": "uuid" },
    "slug": { "type": "string" },
    "title": { "type": "string" },
    "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "status": { "type": "string", "enum": ["draft", "active", "archived"] },
    "artifacts": {
      "type": "object",
      "required": ["total", "pending_review", "approved", "rejected", "archived"],
      "properties": {
        "total": { "type": "integer" },
        "pending_review": { "type": "integer" },
        "approved": { "type": "integer" },
        "rejected": { "type": "integer" },
        "archived": { "type": "integer" }
      }
    },
    "reviews": {
      "type": "object",
      "required": ["total", "pending", "approved", "rejected"],
      "properties": {
        "total": { "type": "integer" },
        "pending": { "type": "integer" },
        "approved": { "type": "integer" },
        "rejected": { "type": "integer" }
      }
    },
    "reports": {
      "type": "object",
      "required": ["total", "geolocated", "critical_open", "by_need_type", "by_severity", "by_triage_priority"],
      "properties": {
        "total": { "type": "integer" },
        "geolocated": { "type": "integer", "description": "lat/lon 皆有、可上圖的通報數" },
        "critical_open": { "type": "integer", "description": "triage 為 critical 且尚未結案的通報數" },
        "by_need_type": { "$ref": "#/$defs/countList" },
        "by_severity": { "$ref": "#/$defs/countList" },
        "by_triage_priority": { "$ref": "#/$defs/countList" }
      }
    },
    "readiness": {
      "type": "object",
      "required": ["bootstrapped", "has_public_content", "has_reports"],
      "properties": {
        "bootstrapped": { "type": "boolean" },
        "has_public_content": { "type": "boolean" },
        "has_reports": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "countList": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "count"],
        "properties": {
          "key": { "type": "string" },
          "count": { "type": "integer" }
        }
      }
    }
  }
}
