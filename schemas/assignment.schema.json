{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://resqlink.dev/schemas/assignment.schema.json",
  "title": "Assignment (Output)",
  "description": "A dispatch record committing a resource offer to a report (need). Created by POST /v1/incidents/{id}/assignments; status advanced via PATCH /v1/assignments/{id}. Creating/advancing keeps the linked report and offer statuses in sync.",
  "type": "object",
  "required": ["id", "incident_id", "report_id", "offer_id", "status", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "incident_id": { "type": "string", "format": "uuid" },
    "report_id": { "type": "string", "format": "uuid", "description": "被處理的通報（需求）。" },
    "offer_id": { "type": "string", "format": "uuid", "description": "被派遣的資源（志工/物資）。" },
    "status": {
      "type": "string",
      "enum": ["assigned", "in_progress", "done", "cancelled"],
      "description": "assigned→in_progress→done/cancelled；done 結案、cancelled 釋回供給。"
    },
    "note": { "type": ["string", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "examples": [
    {
      "id": "11111111-1111-1111-1111-111111111111",
      "incident_id": "22222222-2222-2222-2222-222222222222",
      "report_id": "33333333-3333-3333-3333-333333333333",
      "offer_id": "44444444-4444-4444-4444-444444444444",
      "status": "assigned",
      "note": "就近派工",
      "created_at": "2026-06-16T08:00:00+08:00",
      "updated_at": "2026-06-16T08:00:00+08:00"
    }
  ]
}
