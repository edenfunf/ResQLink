# 本機 Postgres 密碼：必填，docker-compose 會同時注入 db 與 api 兩個服務，
# 不要把實際密碼提交進版控。
POSTGRES_PASSWORD=

# 只有「不透過 docker-compose」直接跑 API 時才需要自行填 DATABASE_URL，
# 密碼請帶入上面的 POSTGRES_PASSWORD，勿寫死在檔案裡：
# DATABASE_URL=postgresql+psycopg://resqlink:<POSTGRES_PASSWORD>@localhost:5432/resqlink

# 選用：設定後，非公開 API 端點需帶 X-API-Key 標頭（留空＝開放 demo 模式）。
ADMIN_API_KEY=

APP_NAME=災鏈 ResQLink API
APP_VERSION=0.1.0
ENVIRONMENT=development

# Demo 模式：生成的元件直接上線（略過人工審核），公開網站/前台一建立就有內容。
# 設 false 可恢復人工審核閘門。
DEMO_AUTO_APPROVE=true

# Optional: enables the AI draft layer (human-in-the-loop). Leave blank to use
# rule-based generation only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 對外公開網站基底（貼文/推播裡的救災入口連結會用到）
WEB_PUBLIC_BASE_URL=http://localhost:3000

# ── 真實對外連接器（全部選用；留空則自動退回「模擬」連接器，demo 仍可跑） ──
# Facebook 粉專發文：需先有粉專 + FB App，取得長期 Page Access Token
# （權限 pages_manage_posts、pages_read_engagement）。
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
FB_GRAPH_API_VERSION=v21.0

# LINE 官方帳號推播：LINE OA 啟用 Messaging API 後取得的 Channel Access Token。
LINE_CHANNEL_ACCESS_TOKEN=

# Google 表單建立：服務帳號 JSON 金鑰（需啟用 Forms API + Drive API）。
# 把金鑰檔放到專案 ./secrets/，再填容器內路徑（例：/secrets/google-service-account.json）。
# 留空＝走模擬。GOOGLE_FORMS_SHARE_WITH 設成你的 Gmail 可把表單分享給你編輯。
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_FORMS_SHARE_WITH=
